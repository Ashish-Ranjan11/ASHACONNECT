# Instant local run uses SQLite automatically if DATABASE_URL is omitted.
# For MySQL, create database awams_db and uncomment:
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/awams_db
SECRET_KEY=change-this-to-a-long-random-secret
FRONTEND_ORIGIN=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=1440
